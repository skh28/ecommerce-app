// Step 1: Database schema for the ecommerce app
// Run: npx prisma generate  &&  npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hashed; we never store plain text
  name      String?
  createdAt DateTime @default(now())

  cartItems CartItem[]
  orders    Order[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int      // store in cents to avoid float issues
  imageUrl    String?
  createdAt   DateTime @default(now())

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  quantity  Int     @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id         String   @id @default(cuid())
  userId     String
  totalCents Int
  createdAt  DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  priceCents Int     // snapshot at time of order

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
